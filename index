<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GreenLavomatic | Laverie automatique premium à Lyon 3</title>
  <meta
    name="description"
    content="GreenLavomatic, laverie automatique à Lyon 3 : lavage, séchage, lockers Mondial Relay, carte de fidélité, SMS de fin de cycle, paiement CB et espèces."
  />
  <style>
    :root {
      --green: #398d57;
      --blue: #204d74;
      --off-white: #f7f5ef;
      --paper: #fcfbf8;
      --light-gray: #e8ece9;
      --mid-gray: #a8b0b4;
      --anthracite: #1f2528;
      --soft-black: #111517;
      --white: #ffffff;
      --shadow-sm: 0 8px 24px rgba(17, 21, 23, 0.08);
      --shadow-md: 0 18px 45px rgba(17, 21, 23, 0.12);
      --shadow-lg: 0 28px 70px rgba(17, 21, 23, 0.18);
      --radius-sm: 12px;
      --radius-md: 20px;
      --radius-lg: 28px;
      --radius-xl: 36px;
      --container: 1200px;
      --header-height: 84px;
      --transition: 280ms cubic-bezier(.2,.8,.2,1);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Inter, "IBM Plex Sans", Manrope, "Segoe UI", Roboto, Arial, sans-serif;
      color: var(--anthracite);
      background:
        radial-gradient(circle at top left, rgba(57, 141, 87, 0.05), transparent 35%),
        radial-gradient(circle at top right, rgba(32, 77, 116, 0.06), transparent 28%),
        var(--paper);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button {
      font: inherit;
      cursor: pointer;
      border: 0;
      background: none;
    }

    .container {
      width: min(calc(100% - 2rem), var(--container));
      margin: 0 auto;
    }

    .section {
      padding: 96px 0;
      position: relative;
    }

    .section-tight {
      padding: 72px 0;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 0.83rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--blue);
      font-weight: 700;
      margin-bottom: 18px;
    }

    .eyebrow::before {
      content: "";
      width: 34px;
      height: 1px;
      background: rgba(32, 77, 116, 0.35);
    }

    .section-head {
      max-width: 760px;
      margin-bottom: 42px;
    }

    .section-head h2 {
      margin: 0 0 16px;
      font-size: clamp(2rem, 3vw, 3.25rem);
      line-height: 1.08;
      letter-spacing: -0.03em;
      color: var(--soft-black);
    }

    .section-head p {
      margin: 0;
      color: #4a555a;
      font-size: 1.04rem;
      max-width: 64ch;
    }

    .grid {
      display: grid;
      gap: 22px;
    }

    .grid-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .grid-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .grid-4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .card {
      background: rgba(255, 255, 255, 0.84);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(31, 37, 40, 0.08);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-sm);
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
      border-color: rgba(57, 141, 87, 0.22);
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.88);
      border: 1px solid rgba(255, 255, 255, 0.18);
      font-size: 0.9rem;
      backdrop-filter: blur(8px);
    }

    .pill.dark {
      background: rgba(32, 77, 116, 0.07);
      border-color: rgba(32, 77, 116, 0.10);
      color: var(--blue);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 52px;
      padding: 0 22px;
      border-radius: 999px;
      font-weight: 700;
      letter-spacing: 0.01em;
      transition: transform var(--transition), box-shadow var(--transition), background var(--transition), color var(--transition), border-color var(--transition);
      white-space: nowrap;
    }

    .btn:hover {
      transform: translateY(-1px);
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--green), #2d7347);
      color: var(--white);
      box-shadow: 0 16px 36px rgba(57, 141, 87, 0.26);
    }

    .btn-primary:hover {
      box-shadow: 0 20px 42px rgba(57, 141, 87, 0.34);
    }

    .btn-secondary {
      color: var(--white);
      border: 1px solid rgba(255, 255, 255, 0.28);
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(8px);
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.14);
    }

    .btn-outline {
      color: var(--blue);
      border: 1px solid rgba(32, 77, 116, 0.18);
      background: rgba(32, 77, 116, 0.04);
    }

    .btn-outline:hover {
      background: rgba(32, 77, 116, 0.08);
    }

    .btn-dark {
      color: var(--white);
      background: var(--soft-black);
      box-shadow: 0 12px 30px rgba(17, 21, 23, 0.18);
    }

    .btn-dark:hover {
      box-shadow: 0 18px 36px rgba(17, 21, 23, 0.24);
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 1000;
      height: var(--header-height);
      display: flex;
      align-items: center;
      transition: background var(--transition), box-shadow var(--transition), border-color var(--transition), transform var(--transition);
      background: rgba(247, 245, 239, 0.78);
      border-bottom: 1px solid rgba(31, 37, 40, 0.06);
      backdrop-filter: blur(10px);
    }

    .site-header.scrolled {
      background: rgba(252, 251, 248, 0.94);
      box-shadow: 0 10px 30px rgba(17, 21, 23, 0.08);
      border-color: rgba(31, 37, 40, 0.08);
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      width: 100%;
      min-height: var(--header-height);
    }

    .brand {
      display: inline-flex;
      flex-direction: column;
      gap: 2px;
      flex-shrink: 0;
    }

    .brand-name {
      font-weight: 800;
      letter-spacing: -0.03em;
      font-size: 1.28rem;
      color: var(--soft-black);
    }

    .brand-sub {
      font-size: 0.74rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--mid-gray);
      font-weight: 700;
    }

    .nav-wrap {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .main-nav {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.62);
      border: 1px solid rgba(31, 37, 40, 0.06);
    }

    .main-nav a {
      position: relative;
      padding: 10px 14px;
      border-radius: 999px;
      color: #364145;
      font-size: 0.95rem;
      font-weight: 600;
      transition: color var(--transition), background var(--transition);
    }

    .main-nav a:hover,
    .main-nav a.active {
      color: var(--blue);
      background: rgba(32, 77, 116, 0.07);
    }

    .menu-toggle {
      display: none;
      width: 48px;
      height: 48px;
      border-radius: 14px;
      border: 1px solid rgba(31, 37, 40, 0.1);
      background: rgba(255, 255, 255, 0.86);
      align-items: center;
      justify-content: center;
      color: var(--soft-black);
      flex-shrink: 0;
    }

    .menu-toggle span,
    .menu-toggle span::before,
    .menu-toggle span::after {
      display: block;
      position: relative;
      width: 18px;
      height: 2px;
      background: currentColor;
      border-radius: 2px;
      transition: transform var(--transition), opacity var(--transition);
      content: "";
    }

    .menu-toggle span::before {
      position: absolute;
      top: -6px;
      left: 0;
    }

    .menu-toggle span::after {
      position: absolute;
      top: 6px;
      left: 0;
    }

    .menu-toggle.open span {
      background: transparent;
    }

    .menu-toggle.open span::before {
      transform: translateY(6px) rotate(45deg);
    }

    .menu-toggle.open span::after {
      transform: translateY(-6px) rotate(-45deg);
    }

    .hero {
      position: relative;
      min-height: calc(100vh - var(--header-height));
      display: flex;
      align-items: center;
      overflow: hidden;
      color: var(--white);
      background:
        linear-gradient(115deg, rgba(17, 21, 23, 0.82) 0%, rgba(17, 21, 23, 0.58) 42%, rgba(32, 77, 116, 0.58) 100%),
        url("https://images.unsplash.com/photo-1517677208171-0bc6725a3e60?auto=format&fit=crop&w=1600&q=80") center/cover no-repeat;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 80% 18%, rgba(57, 141, 87, 0.24), transparent 22%),
        radial-gradient(circle at 12% 78%, rgba(255, 255, 255, 0.06), transparent 20%);
      pointer-events: none;
    }

    .hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.7fr);
      gap: 42px;
      align-items: end;
      padding: 48px 0 56px;
    }

    .hero-copy {
      max-width: 760px;
    }

    .hero-copy h1 {
      margin: 0 0 20px;
      font-size: clamp(2.8rem, 6vw, 5.6rem);
      line-height: 0.96;
      letter-spacing: -0.05em;
      font-weight: 800;
    }

    .hero-copy p {
      margin: 0 0 28px;
      color: rgba(255, 255, 255, 0.84);
      font-size: clamp(1rem, 1.55vw, 1.18rem);
      max-width: 60ch;
    }

    .hero-cta {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 26px;
    }

    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .hero-panel {
      justify-self: end;
      width: 100%;
      max-width: 430px;
      padding: 24px;
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.10);
      border: 1px solid rgba(255, 255, 255, 0.16);
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(16px);
    }

    .hero-panel-top {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 20px;
    }

    .hero-panel h3 {
      margin: 0 0 8px;
      font-size: 1.25rem;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    .hero-panel p {
      margin: 0;
      color: rgba(255, 255, 255, 0.74);
      font-size: 0.96rem;
    }

    .hero-offer {
      padding: 18px;
      border-radius: 22px;
      background: linear-gradient(135deg, rgba(57, 141, 87, 0.22), rgba(255, 255, 255, 0.10));
      border: 1px solid rgba(255, 255, 255, 0.14);
      margin-bottom: 18px;
    }

    .hero-offer-label {
      display: block;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: rgba(255, 255, 255, 0.64);
      margin-bottom: 8px;
      font-weight: 700;
    }

    .hero-offer strong {
      display: block;
      font-size: 1.65rem;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 8px;
    }

    .hero-offer small {
      color: rgba(255, 255, 255, 0.76);
      font-size: 0.92rem;
    }

    .hero-list {
      display: grid;
      gap: 12px;
    }

    .hero-list-item {
      display: flex;
      align-items: center;
      gap: 12px;
      color: rgba(255, 255, 255, 0.86);
      font-size: 0.95rem;
    }

    .hero-list-item::before {
      content: "";
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: #9dd0ae;
      flex-shrink: 0;
      box-shadow: 0 0 0 6px rgba(157, 208, 174, 0.08);
    }

    .hero-bottom-bar {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(17, 21, 23, 0.38);
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(8px);
    }

    .hero-bottom-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0;
    }

    .hero-bottom-item {
      padding: 18px 16px;
      border-right: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hero-bottom-item:last-child {
      border-right: 0;
    }

    .hero-bottom-item strong {
      display: block;
      font-size: 0.92rem;
      color: var(--white);
      margin-bottom: 4px;
      font-weight: 700;
    }

    .hero-bottom-item span {
      color: rgba(255, 255, 255, 0.72);
      font-size: 0.92rem;
    }

    .service-card,
    .why-card,
    .step-card,
    .blog-card,
    .info-card,
    .equipment-card,
    .contact-card,
    .tariff-card {
      padding: 26px;
    }

    .service-card h3,
    .why-card h3,
    .step-card h3,
    .blog-card h3,
    .equipment-card h3,
    .contact-card h3,
    .tariff-card h3 {
      margin: 0 0 10px;
      font-size: 1.16rem;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--soft-black);
    }

    .service-card p,
    .why-card p,
    .step-card p,
    .blog-card p,
    .equipment-card p,
    .contact-card p,
    .tariff-card p {
      margin: 0;
      color: #526066;
      font-size: 0.97rem;
    }

    .service-icon,
    .why-icon,
    .step-index,
    .blog-tag,
    .equipment-icon {
      width: 52px;
      height: 52px;
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
      background: linear-gradient(135deg, rgba(57, 141, 87, 0.12), rgba(32, 77, 116, 0.08));
      border: 1px solid rgba(57, 141, 87, 0.10);
      color: var(--blue);
      font-weight: 800;
      font-size: 1.02rem;
    }

    .services-highlight {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 22px;
      margin-bottom: 22px;
    }

    .feature-panel {
      position: relative;
      overflow: hidden;
      min-height: 360px;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-md);
      background:
        linear-gradient(135deg, rgba(17, 21, 23, 0.62), rgba(32, 77, 116, 0.38)),
        url("https://images.unsplash.com/photo-1626806787461-102c1bfaaea1?auto=format&fit=crop&w=1200&q=80") center/cover no-repeat;
      color: var(--white);
      padding: 34px;
      display: flex;
      flex-direction: column;
      justify-content: end;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .feature-panel h3 {
      margin: 0 0 12px;
      font-size: clamp(1.8rem, 2.4vw, 2.4rem);
      line-height: 1.02;
      letter-spacing: -0.03em;
      max-width: 14ch;
    }

    .feature-panel p {
      margin: 0;
      max-width: 46ch;
      color: rgba(255, 255, 255, 0.82);
    }

    .feature-list {
      display: grid;
      gap: 16px;
    }

    .mini-card {
      padding: 22px;
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(31, 37, 40, 0.08);
      box-shadow: var(--shadow-sm);
    }

    .mini-card strong {
      display: block;
      margin-bottom: 6px;
      font-size: 1rem;
      color: var(--soft-black);
    }

    .mini-card span {
      color: #526066;
      font-size: 0.94rem;
    }

    .equipment-layout {
      display: grid;
      grid-template-columns: 0.88fr 1.12fr;
      gap: 24px;
      align-items: stretch;
    }

    .equipment-visual {
      position: relative;
      overflow: hidden;
      min-height: 460px;
      border-radius: var(--radius-lg);
      background:
        linear-gradient(160deg, rgba(17, 21, 23, 0.18), rgba(17, 21, 23, 0.46)),
        url("https://images.unsplash.com/photo-1604335399105-a0c585fd81a1?auto=format&fit=crop&w=1200&q=80") center/cover no-repeat;
      box-shadow: var(--shadow-md);
    }

    .equipment-badge {
      position: absolute;
      left: 22px;
      right: 22px;
      bottom: 22px;
      padding: 22px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.90);
      border: 1px solid rgba(31, 37, 40, 0.06);
      box-shadow: var(--shadow-md);
    }

    .equipment-badge strong {
      display: block;
      margin-bottom: 6px;
      color: var(--soft-black);
      font-size: 1.06rem;
    }

    .equipment-badge span {
      color: #526066;
      font-size: 0.94rem;
    }

    .equipment-list {
      display: grid;
      gap: 22px;
    }

    .equipment-card ul {
      list-style: none;
      padding: 0;
      margin: 16px 0 0;
      display: grid;
      gap: 12px;
    }

    .equipment-card li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 12px 14px;
      border-radius: 14px;
      background: rgba(32, 77, 116, 0.04);
      border: 1px solid rgba(32, 77, 116, 0.07);
      color: #304047;
      font-size: 0.96rem;
    }

    .equipment-card li strong {
      color: var(--soft-black);
      font-size: 0.98rem;
      font-weight: 700;
    }

    .why-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .tariffs-wrap {
      display: grid;
      grid-template-columns: 1fr 0.92fr;
      gap: 24px;
      align-items: start;
    }

    .tariffs-table {
      overflow: hidden;
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(31, 37, 40, 0.08);
      box-shadow: var(--shadow-md);
    }

    .tariffs-table table {
      width: 100%;
      border-collapse: collapse;
    }

    .tariffs-table thead th {
      text-align: left;
      padding: 22px 24px;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #6d7a80;
      background: rgba(32, 77, 116, 0.05);
      border-bottom: 1px solid rgba(31, 37, 40, 0.07);
    }

    .tariffs-table tbody td {
      padding: 20px 24px;
      border-bottom: 1px solid rgba(31, 37, 40, 0.07);
      color: #344045;
      font-size: 0.98rem;
    }

    .tariffs-table tbody tr:last-child td {
      border-bottom: 0;
    }

    .tariffs-table tbody td:last-child {
      font-weight: 800;
      color: var(--soft-black);
      text-align: right;
      white-space: nowrap;
    }

    .tariffs-note {
      margin-top: 14px;
      color: #617076;
      font-size: 0.93rem;
    }

    .tariff-card {
      min-height: 100%;
      background:
        linear-gradient(160deg, rgba(32, 77, 116, 0.96), rgba(17, 21, 23, 0.98));
      color: rgba(255, 255, 255, 0.9);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      border: 1px solid rgba(255, 255, 255, 0.06);
      overflow: hidden;
      position: relative;
    }

    .tariff-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at top right, rgba(57, 141, 87, 0.25), transparent 25%),
        radial-gradient(circle at bottom left, rgba(255, 255, 255, 0.06), transparent 24%);
      pointer-events: none;
    }

    .tariff-card > * {
      position: relative;
      z-index: 1;
    }

    .tariff-card h3,
    .tariff-card p,
    .tariff-card li {
      color: inherit;
    }

    .tariff-card .price-highlight {
      font-size: 3rem;
      line-height: 1;
      font-weight: 800;
      letter-spacing: -0.05em;
      margin: 18px 0 6px;
      color: var(--white);
    }

    .tariff-card .subprice {
      display: inline-block;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.10);
      border: 1px solid rgba(255, 255, 255, 0.12);
      font-size: 0.88rem;
      margin-bottom: 20px;
    }

    .tariff-card ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 12px;
    }

    .tariff-card li {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.97rem;
      color: rgba(255, 255, 255, 0.84);
    }

    .tariff-card li::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #a6d5b6;
      flex-shrink: 0;
    }

    .loyalty-section {
      overflow: hidden;
    }

    .loyalty-wrap {
      position: relative;
      display: grid;
      grid-template-columns: 1.06fr 0.94fr;
      gap: 24px;
      align-items: stretch;
      padding: 28px;
      border-radius: var(--radius-xl);
